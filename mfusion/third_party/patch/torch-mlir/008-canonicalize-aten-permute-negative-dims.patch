+void AtenPermuteOp::getCanonicalizationPatterns(RewritePatternSet &patterns,
+                                                MLIRContext *context) {
+  patterns.add(+[](AtenPermuteOp op,
+                   PatternRewriter &rewriter) -> LogicalResult {
+    auto selfType = dyn_cast<ValueTensorType>(op.getSelf().getType());
+    if (!selfType || !selfType.hasSizes())
+      return failure();
+
+    SmallVector<int64_t> dims;
+    if (!matchPattern(op.getDims(), m_TorchListOfConstantInts(dims)))
+      return failure();
+
+    int64_t rank = selfType.getSizes().size();
+    bool changed = false;
+    SmallVector<Value> normalizedDims;
+    normalizedDims.reserve(dims.size());
+    for (int64_t dim : dims) {
+      int64_t normalized = dim < 0 ? dim + rank : dim;
+      changed |= normalized != dim;
+      normalizedDims.push_back(
+          rewriter.create<Torch::ConstantIntOp>(op.getLoc(), normalized));
+    }
+
+    if (!changed)
+      return failure();
+
+    Value dimsList = rewriter.create<Torch::PrimListConstructOp>(
+        op.getLoc(), op.getDims().getType(), normalizedDims);
+    rewriter.replaceOpWithNewOp<AtenPermuteOp>(op, op.getType(), op.getSelf(),
+                                               dimsList);
+    return success();
+  });
+}
