#include "mfusion/Conversion/DialectConversion.pdll"
#include "mfusion/Conversion/PdllHelper.pdll"
#include "torch-mlir/Dialect/Torch/IR/TorchOps.td"
#include "mfusion/Dialect/Mfuse/MfuseOps.td"

#include "MfuseMetaToTorch.pdll"
#include "MfuseAclnnToTorch.pdll"

Pattern ConvertReturnOp {
  let root = op<func.return>(operands: ValueRange);
  replace root with op<func.return>(convertValues(operands));
}
