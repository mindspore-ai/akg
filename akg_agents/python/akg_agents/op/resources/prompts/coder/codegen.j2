        # Grid大小检查（Ascend限制）
        BLOCK_SIZE = 128
        grid = (triton.cdiv(B * N, BLOCK_SIZE),)
        assert grid[0] < 65536, f"Grid size {grid[0]} exceeds Ascend limit (65536)"
        
        # 调用kernel
        return kernel(...)
