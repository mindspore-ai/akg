def _to_cpu_golden_dtype(tensor: torch.Tensor) -> torch.Tensor:
    """Move tensor to CPU for golden while preserving non-floating dtypes."""
    tensor_cpu = tensor.detach().cpu()
    return tensor_cpu.double() if tensor_cpu.is_floating_point() else tensor_cpu

def _to_cpu_native_dtype(tensor: torch.Tensor) -> torch.Tensor:
    """Move tensor to CPU while preserving its native dtype."""
    return tensor.detach().cpu()

def _map_tensor_values(value, tensor_fn):
    if isinstance(value, torch.Tensor):
        return tensor_fn(value)
    if isinstance(value, list):
        return [_map_tensor_values(item, tensor_fn) for item in value]
    if isinstance(value, tuple):
        return tuple(_map_tensor_values(item, tensor_fn) for item in value)
    return value

def _build_params_from_signature(func, input_tensors, case_attrs):
    """Build kwargs the same way kernel_eval does after golden.get_input."""
    params = {}
    tensor_idx = 0
    sig = signature(func)
    for param_name, param in sig.parameters.items():
        annotation = str(param.annotation) if param.annotation != Parameter.empty else ""
        if "Tensor" in annotation:
            params[param_name] = input_tensors[tensor_idx] if tensor_idx < len(input_tensors) else None
            tensor_idx += 1
        elif param_name in case_attrs:
            params[param_name] = case_attrs[param_name]
        elif param.default != Parameter.empty:
            params[param_name] = param.default
    return params

# Timeout decorator
def timeout_handler(signum, frame):
    raise TimeoutError("计算超时")

def with_timeout(timeout_seconds):
    def decorator(func):
        @functools.wraps(func)
        def wrapper(*args, **kwargs):
            old_handler = signal.signal(signal.SIGALRM, timeout_handler)
            signal.alarm(timeout_seconds)
            try:
                result = func(*args, **kwargs)
                return result
            finally:
                signal.alarm(0)
                signal.signal(signal.SIGALRM, old_handler)
        return wrapper
    return decorator


