    @with_timeout(300)
    def verify_workload(workload, wl_idx):
        # Merge axes
        axes_and_scalars = {}
        for key, val in definition.get("axes", {}).items():
            if val.get("type") == "const":
                axes_and_scalars[key] = val.get("value")
        axes_and_scalars.update(workload.get("axes", {}))
        
        tol_dict = workload.get("tolerance", {})
        tolerance = ToleranceSpec(**tol_dict)
        
        for round_idx in range(10):
            set_seed(42 + round_idx)
            
            # Generate inputs
            inputs_dict = get_inputs(axes_and_scalars, device)
            
            # Run reference
            ref_outputs = ref_run(**inputs_dict)
            if not isinstance(ref_outputs, (list, tuple)):
                ref_outputs = [ref_outputs]
                
            # Prepare inputs for impl_model
            inputs_for_impl = [inputs_dict[name] for name in input_names]
            
            # Run implementation
            try:
                impl_outputs = impl_model(*inputs_for_impl)
            except Exception as e:
                raise RuntimeError(f"Implementation execution failed: {e}\n{traceback.format_exc()}")
                
            if not isinstance(impl_outputs, (list, tuple)):
                impl_outputs = [impl_outputs]
                
            if len(ref_outputs) != len(impl_outputs):
                raise AssertionError(f"Output count mismatch: ref={len(ref_outputs)}, impl={len(impl_outputs)}")
                
            # Compare outputs
            for i, (ref_out, impl_out) in enumerate(zip(ref_outputs, impl_outputs)):
                if ref_out is None or impl_out is None:
                    raise AssertionError(f"Output {i} is None: ref={ref_out is None}, impl={impl_out is None}")
                    
                if ref_out.shape != impl_out.shape:
                    raise AssertionError(f"Shape mismatch at output {i}: ref={ref_out.shape}, impl={impl_out.shape}")
                    
                if ref_out.dtype != impl_out.dtype:
                    raise AssertionError(f"Dtype mismatch at output {i}: ref={ref_out.dtype}, impl={impl_out.dtype}")
                    
                correctness, exceeds = compute_error_stats(impl_out, ref_out, tolerance)
                if exceeds:
                    msg = f"Verification failed at output {i}\n"
                    msg += f"Max absolute error: {correctness.max_absolute_error}\n"
                    msg += f"Max relative error: {correctness.max_relative_error}\n"
                    if correctness.has_nan:
                        msg += "Contains NaN\n"
                    if correctness.has_inf:
                        msg += "Contains Inf\n"
                    raise AssertionError(msg)
                    
        return True

    import time
    import uuid
    verification_id = str(uuid.uuid4())[:8]
    timestamp = time.strftime("%Y-%m-%d %H:%M:%S", time.localtime())
    
    for idx, workload in enumerate(workloads):
        try:
            verify_workload(workload, idx)
            passed_workloads += 1
            print(f"[{verification_id}] Workload {idx+1}/{total_workloads} PASSED")
        except Exception as e:
            print(f"[{verification_id}] Workload {idx+1}/{total_workloads} FAILED: {e}")
            
    if passed_workloads == total_workloads:
