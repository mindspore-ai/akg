    def verify_single_case(inputs_for_framework, inputs_for_impl, reference_output=None):
        """三阶段 per-case 验证：framework / impl / compare 各自独立 try。

        Returns a per-case dict consumed by `verify_implementations`'s
        result collector:

            {"correctness": bool,
             "error_source": "ref" | "kernel" | None,
             "failure_kind": "ref_crash" | "kernel_crash"
                           | "kernel_miss" | "compare_crash" | None,
             "error": str | None,           # one-line summary
             "traceback": str | None,       # full traceback on FAIL
             "framework_output": list | None}

        Caller adds `idx` and `case_desc` before writing it to
        verify_result.json. The three-stage split is what lets the
        sidecar attribute failures to ref-side vs kernel-side rather
        than collapsing every failure to "kernel".
        """
        import traceback as _tb

        case_result = {
            "correctness": False,
            "error_source": None,
            "failure_kind": None,
            "error": None,
            "traceback": None,
            "framework_output": None,
        }

        # ---- Stage 1: framework / reference output ----
        # Seed before the framework forward so non-deterministic ops
        # (dropout, init) line up across ref vs. impl.
        try:
            {% for line in set_seed_code %}
            {{ line }}
            {% endfor %}

            if reference_output is not None:
                # Cross-backend conversion path — skip base model.
                framework_output = reference_output
                print("[INFO] 使用参考数据作为 ground truth（跳过 base model 执行）")
            else:
                framework_output = framework_model(*inputs_for_framework)

            if not isinstance(framework_output, (list, tuple)):
                framework_output = [framework_output]
            case_result["framework_output"] = framework_output
        except Exception as e:
            case_result["error_source"] = "ref"
            case_result["failure_kind"] = "ref_crash"
            case_result["error"] = "ref-side: " + type(e).__name__ + ": " + str(e)
            case_result["traceback"] = _tb.format_exc()
            return case_result

        # ---- Stage 2: implementation output ----
        # call_impl_code is the DSLAdapter hook that defines `impl_output`.
        # We wrap it in its own try so a kernel crash gets blamed on the
        # kernel side rather than masquerading as a "ref" issue.
        try:
            {% for line in call_impl_code %}
            {{ line }}
            {% endfor %}

            if not isinstance(impl_output, (list, tuple)):
                impl_output = [impl_output]
        except Exception as e:
            case_result["error_source"] = "kernel"
            case_result["failure_kind"] = "kernel_crash"
            case_result["error"] = "kernel-side: " + type(e).__name__ + ": " + str(e)
            case_result["traceback"] = _tb.format_exc()
            return case_result

        # ---- Stage 3: compare ----
        # compare_outputs_code (FrameworkAdapter hook) raises on mismatch.
        # An AssertionError = numerical miss = kernel_miss. Any other
        # exception bubbling out of the comparator = compare_crash.
        try:
            if len(framework_output) != len(impl_output):
                raise AssertionError(
                    "验证失败，输出数量不一致: framework=" + str(len(framework_output))
                    + ", impl=" + str(len(impl_output)))

            for i, (fw_out, impl_out) in enumerate(zip(framework_output, impl_output)):
                if fw_out is None or impl_out is None:
                    raise AssertionError(
                        "输出" + str(i) + "为None: framework=" + str(fw_out is None)
                        + ", impl=" + str(impl_out is None))

                {% for line in compare_outputs_code %}
                {{ line }}
                {% endfor %}
        except AssertionError as e:
            case_result["error_source"] = "kernel"
            case_result["failure_kind"] = "kernel_miss"
            case_result["error"] = "compare: " + str(e)
            case_result["traceback"] = _tb.format_exc()
            return case_result
        except Exception as e:
            case_result["error_source"] = "kernel"
            case_result["failure_kind"] = "compare_crash"
            case_result["error"] = "compare: " + type(e).__name__ + ": " + str(e)
            case_result["traceback"] = _tb.format_exc()
            return case_result

        case_result["correctness"] = True
        return case_result

    def verify_with_timeout(inputs_for_framework, inputs_for_impl, reference_output=None, timeout_msg=None, success_msg=None):
        """带超时控制的验证函数 — 返回 verify_single_case 的 dict。"""
        @with_timeout({{ timeout }})
        def verify_case():
            return verify_single_case(inputs_for_framework, inputs_for_impl, reference_output)

        try:
            case_result = verify_case()
        except TimeoutError:
            import traceback as _tb
            return {
                "correctness": False,
                "error_source": "kernel",
                "failure_kind": "kernel_crash",
                "error": "timeout: " + (timeout_msg or ("验证超时（" + str({{ timeout }}) + "秒）")),
                "traceback": _tb.format_exc(),
                "framework_output": None,
            }

        if case_result.get("correctness") and success_msg:
            print(success_msg)
        return case_result

