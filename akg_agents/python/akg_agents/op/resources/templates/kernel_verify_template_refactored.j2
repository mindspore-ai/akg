    # Per-case result collector — drained into verify_result.json at
    # the bottom of this function so the host (KernelVerifier.run +
    # eval_kernel.py) can reconstruct the autoresearch sidecar with
    # idx / case_desc / error_source / failure_kind preserved.
    per_case_results = []
    framework_output = None  # last successful framework_output (for shape/dtype logging)

    def _shape_desc(x):
        """One-line shape/dtype description for per-shape rows."""
        try:
            shape = tuple(x.shape) if hasattr(x, "shape") else None
            dtype = str(x.dtype) if hasattr(x, "dtype") else type(x).__name__
            return "shape=" + str(shape) + " dtype=" + dtype
        except Exception:
            return type(x).__name__

    def _case_desc(case_inputs):
        """Render an `inputs[0..N]` summary string."""
        try:
            parts = [_shape_desc(x) for x in case_inputs[:4]]
            return "inputs[" + str(len(case_inputs)) + "]: " + ", ".join(parts) + (
                ", ..." if len(case_inputs) > 4 else "")
        except Exception:
            return "inputs[?]"

    {% if is_dynamic_shape %}
    # 动态shape：获取多组输入数据
    # 设置随机种子以确保数据可复现（先准备impl输入）
    {% for line in set_seed_code %}
    {{ line }}
    {% endfor %}
    impl_inputs_list = get_inputs_dyn_list()

    # 再次设置随机种子，重新生成framework输入（确保与impl一致）
    {% for line in set_seed_code %}
    {{ line }}
    {% endfor %}
    framework_inputs_list = get_inputs_dyn_list()

    # 对每组输入进行验证 — 即使中间 case 失败也跑完后续 case，让 sidecar
    # 拿到完整的 per_case 视图（旧 in-process 路径同样的行为）。
    for case_idx, (inputs_for_impl, inputs_for_framework) in enumerate(zip(impl_inputs_list, framework_inputs_list)):
        {% if framework == "torch" %}
        inputs_for_impl = [process_input(x) for x in inputs_for_impl]
        inputs_for_framework = [process_input(x) for x in inputs_for_framework]
        {% endif %}

        print("验证动态shape案例 " + str(case_idx + 1) + "/" + str(len(framework_inputs_list)))

        case_result = verify_with_timeout(
            inputs_for_framework,
            inputs_for_impl,
            timeout_msg="动态shape案例 " + str(case_idx + 1) + " 验证超时（" + str({{ timeout }}) + "秒）",
            success_msg="动态shape案例 " + str(case_idx + 1) + " 验证成功",
        )
        case_result["idx"] = case_idx
        case_result["case_desc"] = _case_desc(inputs_for_framework)
        if case_result.get("framework_output") is not None and framework_output is None:
            framework_output = case_result["framework_output"]
        # framework_output is heavy (tensors); don't serialize it into JSON.
        case_result.pop("framework_output", None)
        per_case_results.append(case_result)

    {% else %}
    # 静态shape：获取单组输入数据
    {% if use_reference_inputs %}
    inputs_for_impl = [process_input(x) for x in reference_inputs]
    inputs_for_framework = inputs_for_impl
    {% else %}
    # 设置随机种子以确保数据可复现（先准备impl输入）
    {% for line in set_seed_code %}
    {{ line }}
    {% endfor %}
    inputs_for_impl = get_inputs()
    {% if framework == "torch" %}
    inputs_for_impl = [process_input(x) for x in inputs_for_impl]
    {% endif %}

    # 重新生成输入数据用于framework（避免原地操作影响）
    {% for line in set_seed_code %}
    {{ line }}
    {% endfor %}
    inputs_for_framework = get_inputs()
    {% if framework == "torch" %}
    inputs_for_framework = [process_input(x) for x in inputs_for_framework]
    {% endif %}
    {% endif %}

    # 获取参考输出（如果使用参考数据模式）
    ref_output_for_case = None
    if use_reference_data and reference_outputs:
        # 参考数据模式：使用预先生成的参考输出
        ref_output_for_case = reference_outputs
        # 将参考输出移动到当前设备
        {% if framework == "torch" %}
        ref_output_for_case = [x.to(device) if hasattr(x, 'to') else x for x in ref_output_for_case]
        {% endif %}

    case_result = verify_with_timeout(
        inputs_for_framework,
        inputs_for_impl,
        reference_output=ref_output_for_case,
        timeout_msg="静态shape验证超时（" + str({{ timeout }}) + "秒）",
    )
    case_result["idx"] = 0
    case_result["case_desc"] = _case_desc(inputs_for_framework)
    if case_result.get("framework_output") is not None:
        framework_output = case_result["framework_output"]
    case_result.pop("framework_output", None)
    per_case_results.append(case_result)
    {% endif %}

    # ------------------------------------------------------------------
    # Aggregate per_case_results into verify_result.json (autoresearch
    # sidecar shape). The host (KernelVerifier.run -> eval_kernel.py)
    # reads this file next to the verify script to populate the
    # `.eval_result.json` `verify` block.
    # ------------------------------------------------------------------
    failed_indices = [c["idx"] for c in per_case_results if not c.get("correctness")]
    overall_correct = len(failed_indices) == 0
    # ref-side failures take priority — they invalidate the whole eval
    # regardless of what the kernel does (matches old in-process logic).
    overall_error_source = None
    for c in per_case_results:
        if c.get("error_source") == "ref":
            overall_error_source = "ref"
            break
    if overall_error_source is None:
        for c in per_case_results:
            if c.get("error_source") == "kernel":
                overall_error_source = "kernel"
                break

    diagnostics = []
    for c in per_case_results:
        if c.get("traceback"):
            diagnostics.append("[case " + str(c["idx"]) + "] " + c["traceback"])

    sidecar = {
        "correctness": overall_correct,
        "error_source": overall_error_source,
        "ref_source": "computed",
        "num_cases": len(per_case_results),
        "failed_indices": failed_indices,
        "per_case": [{
            "idx": c["idx"],
            "case_desc": c.get("case_desc", ""),
            "correctness": c.get("correctness", False),
            "error": c.get("error"),
            "error_source": c.get("error_source"),
            "failure_kind": c.get("failure_kind"),
        } for c in per_case_results],
        "diagnostics": diagnostics,
        # max_abs_diff is not exposed by the FrameworkAdapter compare hook
        # (it raises on mismatch and surfaces the diff in the message
        # string). Leave the worst_* keys as None so eval_client doesn't
        # KeyError; future work can wire compare to return max_abs_diff
        # and we'd fill these in here.
        "worst_idx": None,
        "worst_max_abs_diff": None,
    }

    sidecar_path = os.path.join(os.path.dirname(os.path.abspath(__file__)),
                                "verify_result.json")
    try:
        with open(sidecar_path, "w", encoding="utf-8") as _fp:
            json.dump(sidecar, _fp, ensure_ascii=False, default=str)
        print("[INFO] verify_result.json -> " + sidecar_path)
    except Exception as _e:
        print("[WARN] 写入 verify_result.json 失败: " + str(_e))

    if not overall_correct:
        # Surface the first failure as an AssertionError so the existing
        # worker.verify (passed, log) contract still flips to FAIL — the
        # sidecar is the structured channel, the log is the legacy one.
        first_fail = next(c for c in per_case_results if not c.get("correctness"))
        raise AssertionError(
            "[case " + str(first_fail["idx"]) + "] "
            + str(first_fail.get("error") or "verify failed"))
    
    # 构建验证成功信息
    import time
    import uuid
    
    # 生成唯一标识符，避免并发时的日志混乱
    verification_id = str(uuid.uuid4())[:8]
    timestamp = time.strftime("%Y-%m-%d %H:%M:%S", time.localtime())
    
    # 收集验证的基础信息
    verification_info = {
        "verification_id": verification_id,
        "timestamp": timestamp,
        "op_name": "{{ op_name }}",
        "framework": "{{ framework }}",
        "backend": "{{ backend }}",
        "arch": "{{ arch }}",
        "dsl": "{{ dsl }}",
        "device_id": {{ device_id }},
        "status": "成功"
    }
    
    # 收集验证信息
    {% if is_dynamic_shape %}
    verification_info.update({
        "shape_type": "dynamic",
        "case_count": len(framework_inputs_list)
    })
    shape_info = f"形状类型: 动态 | 验证案例数: {len(framework_inputs_list)}"
    {% else %}
    output_shapes = [str(out.shape) if hasattr(out, 'shape') else str(type(out)) for out in framework_output]
    output_dtypes = [str(out.dtype) if hasattr(out, 'dtype') else str(type(out)) for out in framework_output]
    verification_info.update({
        "shape_type": "static",
        "output_count": len(output_shapes),
        "output_shapes": output_shapes,
        "output_dtypes": output_dtypes
    })
    shape_info = f"形状类型: 静态 | 输出数量: {len(output_shapes)} | 形状: {output_shapes} | 数据类型: {output_dtypes}"
    {% endif %}
    
    # 格式化输出，确保并发时不会混乱
    verification_log = f"""[{verification_id}] 验证结果: 成功
[{verification_id}] 算子: {{ op_name }} | 框架: {{ framework }} | 后端: {{ backend }} | 架构: {{ arch }}
[{verification_id}] DSL: {{ dsl }} | 设备ID: {{ device_id }} | 时间: {timestamp}
[{verification_id}] {shape_info}
[{verification_id}] {'='*60}\n\n"""
    
    print(verification_log)


