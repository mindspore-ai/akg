    {% endfor %}

        # 设置随机种子 (generated by FrameworkAdapter)
        {% for line in set_seed_code %}
        {{ line }}
        {% endfor %}

        # 获取初始化参数和输入数据
        init_params = get_init_inputs()
        framework_model = FrameworkModel(*init_params)

        {% if framework == "torch" %}
        framework_model = framework_model.to(device)
        {% endif %}

        # 输入处理函数 (generated by FrameworkAdapter)
    {% for line in process_input_code %}
        {{ line }}
    {% endfor %}

        def run_benchmark(inputs):
            """运行基准测试"""
    {% for line in benchmark_code %}
            {{ line }}
    {% endfor %}

            return execution_time_ms, method

        # Same canonical per-case schema as profile_generation: ``per_case_us``
        # is always populated (single-element list for static-shape), with
        # ``execution_time_us`` carrying the aggregate mean for legacy readers.
        {% if is_dynamic_shape %}
        inputs_list = get_inputs_dyn_list()
        per_case_us = []
        method = None
        for case_idx, inputs in enumerate(inputs_list):
            {% if framework == "torch" %}
            inputs = [process_input(x) for x in inputs]
            {% endif %}
            case_ms, method = run_benchmark(inputs)
            case_us = case_ms * 1000.0
            per_case_us.append(case_us)
            print(f"[{{ op_name }}] Case {case_idx + 1} execution time: {case_us:.4f} us")
        avg_us = sum(per_case_us) / len(per_case_us)
        print(f"[{{ op_name }}] Average execution time: {avg_us:.4f} us")
        shape_type = "dynamic"

        {% else %}
        {% if framework == "torch" %}
        inputs = get_inputs()
        inputs = [process_input(x) for x in inputs]
        {% elif framework == "numpy" %}
        inputs = get_inputs()
        {% elif framework == "mindspore" %}
        inputs = get_inputs()
        {% endif %}
        case_ms, method = run_benchmark(inputs)
        case_us = case_ms * 1000.0
        per_case_us = [case_us]
        avg_us = case_us
        print(f"[{{ op_name }}] Base execution time: {case_us:.4f} us")
        shape_type = "static"
        {% endif %}

        result_data = {
            "execution_time_us": avg_us,
            "execution_time_ms": avg_us / 1000.0,
            "per_case_us": per_case_us,
            "case_count": len(per_case_us),
            "warmup_times": {{ warmup_times }},
            "run_times": {{ run_times }},
            "method": method,
            "shape_type": shape_type,
        }

    except Exception as e:
        print(f"[{{ op_name }}] Base profiling failed: {e}", flush=True)
        import traceback; traceback.print_exc()
        result_data = {
            "execution_time_ms": None,
            "execution_time_us": None,
            "error": str(e),
        }
    finally:
        if result_data is not None:
            # inf/nan → None: 保证 json 文件始终写出.
            # profiler_npu → collect_time 在 NPU profiler trace 数据缺失时
            # (如 op_statistic.csv 未生成) 返回 float('inf').
            # json.dump 无法序列化 inf, 会抛 ValueError 导致 json 文件
            # 未写出, 上层 read_profile_result_from_json 随后抛
            # FileNotFoundError. 替换为 None 切断此链路, 下游读到 None
            # 即视为 profiling 失败, 走正常 FAIL 路径.
            for k, v in result_data.items():
                if isinstance(v, float) and (v != v or v == float('inf') or v == float('-inf')):
                    result_data[k] = None
            with open("base_profile_result.json", "w") as f:
                json.dump(result_data, f, indent=2)

if __name__ == "__main__":
    run_base_implementations()

