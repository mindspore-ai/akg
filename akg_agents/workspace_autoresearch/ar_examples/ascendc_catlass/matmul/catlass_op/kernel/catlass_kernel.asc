#ifndef K_MAX_SHAPE_DIM
#define K_MAX_SHAPE_DIM 0
#endif

#include "catlass/gemm/kernel/basic_matmul.hpp"
#include "catlass/gemm/kernel/optimized_matmul.hpp"
#include "catlass/gemm/kernel/splitk_matmul.hpp"

#include "catlass/arch/arch.hpp"
#include "catlass/catlass.hpp"
#include "catlass/gemm/block/block_mmad.hpp"
#include "catlass/gemm/block/block_swizzle.hpp"
#include "catlass/gemm/device/device_gemm.hpp"
#include "catlass/gemm/dispatch_policy.hpp"
#include "catlass/gemm/gemm_type.hpp"
#include "catlass/layout/layout.hpp"
#include "catlass/status.hpp"

using namespace Catlass;

using ElementA = half;
using ElementB = half;
using ElementC = half;

using LayoutA = layout::RowMajor;
using LayoutB = layout::RowMajor;
using LayoutC = layout::RowMajor;

using ArchTag = Arch::AtlasA2;
using DispatchPolicy = Gemm::MmadAtlasA2Pingpong<true>;
using L1TileShape = GemmShape<128, 256, 256>;
using L0TileShape = GemmShape<128, 256, 64>;

using AType = Gemm::GemmType<ElementA, LayoutA>;
using BType = Gemm::GemmType<ElementB, LayoutB>;
using CType = Gemm::GemmType<ElementC, LayoutC>;

using BlockMmad = Gemm::Block::BlockMmad<DispatchPolicy, L1TileShape, L0TileShape, AType, BType, CType>;
using BlockEpilogue = void;
using BlockScheduler = typename Gemm::Block::GemmIdentityBlockSwizzle<3, 0>;

using MatmulKernel = Gemm::Kernel::BasicMatmul<BlockMmad, BlockEpilogue, BlockScheduler>;

extern "C" __global__ __aicore__ void basic_matmul_impl(MatmulKernel::Params params)
{
    MatmulKernel op;
    op(params);
}

namespace catlass_kernel {

void basic_matmul(uint32_t coreNum, void* stream, uint32_t M, uint32_t N, uint32_t K,
                  uint8_t* ptrA, uint8_t* ptrB, uint8_t* ptrC)
{
    GemmCoord problemShape(M, N, K);
    MatmulKernel::Arguments args{problemShape, ptrA, ptrB, ptrC};
    MatmulKernel::Params params = MatmulKernel::ToUnderlyingArguments(args, nullptr);
    basic_matmul_impl<<<coreNum, nullptr, stream>>>(params);
}

} // namespace catlass_kernel

// --- SplitK Matmul ---

using SplitkL1TileShape = GemmShape<128, 256, 256>;
using SplitkL0TileShape = GemmShape<128, 256, 64>;

using SplitkAType = Gemm::GemmType<half, layout::RowMajor>;
using SplitkBType = Gemm::GemmType<half, layout::ColumnMajor>;
using SplitkCType = Gemm::GemmType<float, layout::RowMajor>;

using SplitkBlockMmad = Gemm::Block::BlockMmad<DispatchPolicy, SplitkL1TileShape, SplitkL0TileShape,
                                               SplitkAType, SplitkBType, SplitkCType>;
using SplitkBlockEpilogue = void;

constexpr uint32_t SPLITK_COMPUTE_LENGTH = 192 * 1024 / sizeof(float);
using SplitkReduceAdd = Catlass::Gemm::Kernel::SplitkReduceAdd<Arch::AtlasA2, float, half, 1, SPLITK_COMPUTE_LENGTH>;

using SplitkBlockScheduler = typename Gemm::Block::SplitkGemmIdentityBlockSwizzle<3, 0>;

using SplitkMatmulKernel = Gemm::Kernel::SplitkMatmul<SplitkBlockMmad, SplitkBlockEpilogue,
                                                       SplitkBlockScheduler, SplitkReduceAdd>;

extern "C" __global__ __aicore__ void splitk_matmul_impl(SplitkMatmulKernel::Params params)
{
    SplitkMatmulKernel op;
    op(params);
}

namespace catlass_kernel {

size_t get_splitk_matmul_workspace_size(uint32_t coreNum, uint32_t M, uint32_t N, uint32_t K)
{
    GemmCoord problemShape(M, N, K);
    SplitkMatmulKernel::Arguments args{problemShape, coreNum, sizeof(float), nullptr, nullptr, nullptr};
    return SplitkMatmulKernel::GetWorkspaceSize(args);
}

void splitk_matmul(uint32_t coreNum, void* stream, uint32_t M, uint32_t N, uint32_t K,
                   uint8_t* ptrA, uint8_t* ptrB, uint8_t* ptrC, uint8_t* workspace)
{
    GemmCoord problemShape(M, N, K);
    SplitkMatmulKernel::Arguments args{problemShape, coreNum, sizeof(float), ptrA, ptrB, ptrC};
    SplitkMatmulKernel::Params params = SplitkMatmulKernel::ToUnderlyingArguments(args, workspace);
    splitk_matmul_impl<<<coreNum, nullptr, stream>>>(params);
}

// --- Optimized Matmul ---

template <class ArchTag, class AType, class BType, class CType, class BiasType = void>
struct OptTileCopy : public Gemm::Tile::TileCopy<ArchTag, AType, BType, CType, BiasType> {
    using Base = Gemm::Tile::TileCopy<ArchTag, AType, BType, CType, BiasType>;
    using CopyGmToL1A = typename Base::CopyGmToL1A;
    using CopyGmToL1B = typename Base::CopyGmToL1B;
    using CopyL1ToL0A = typename Base::CopyL1ToL0A;
    using CopyL1ToL0B = typename Base::CopyL1ToL0B;
    using CopyL0CToGm = typename Base::CopyL0CToGm;
    using BiasTypeSelector = typename Base::BiasTypeSelector;
    using CopyGmToL1Bias = typename Base::CopyGmToL1Bias;
    using CopyL1ToBT = typename Base::CopyL1ToBT;
};

constexpr uint32_t OPT_ALIGN_BYTE = 512;
constexpr uint32_t OPT_ALIGN_ELEM = OPT_ALIGN_BYTE / sizeof(half);
constexpr bool OPT_ENABLE_UNIT = true;
constexpr bool OPT_ENABLE_SHUFFLE_K = true;

using OptElementA = half;
using OptElementB = half;
using OptElementC = half;
using OptLayoutA = layout::RowMajor;
using OptLayoutB = layout::ColumnMajor;
using OptLayoutC = layout::RowMajor;

using OptAType = Gemm::GemmType<OptElementA, OptLayoutA>;
using OptBType = Gemm::GemmType<OptElementB, OptLayoutB>;
using OptCType = Gemm::GemmType<OptElementC, OptLayoutC>;
using OptDispatchPolicy = Gemm::MmadAtlasA2Preload<OPT_ENABLE_UNIT, OPT_ENABLE_SHUFFLE_K>;

using OptL1TileShape = std::conditional_t<
    std::is_same_v<OptLayoutA, layout::ColumnMajor> && std::is_same_v<OptLayoutB, layout::ColumnMajor>,
    GemmShape<256, 128, 256>, GemmShape<128, 256, 256>>;
using OptL0TileShape = std::conditional_t<
    std::is_same_v<OptLayoutA, layout::ColumnMajor> && std::is_same_v<OptLayoutB, layout::ColumnMajor>,
    GemmShape<256, 128, 64>, GemmShape<128, 256, 64>>;

using OptBlockScheduler30 = Gemm::Block::GemmIdentityBlockSwizzle<3, 0>;
using OptBlockScheduler31 = Gemm::Block::GemmIdentityBlockSwizzle<3, 1>;
using OptBlockEpilogue = void;

using OptPaddingTag = Gemm::Kernel::PaddingTag;
constexpr OptPaddingTag OPT_PAD_TAG_A = OptPaddingTag::PADDING_NZ;
constexpr OptPaddingTag OPT_PAD_TAG_B = OptPaddingTag::PADDING_NZ;
constexpr uint32_t OPT_COMP_LEN_A = 48 * 1024 / sizeof(OptElementA);
constexpr uint32_t OPT_COMP_LEN_B = 48 * 1024 / sizeof(OptElementB);

using OptPadBuilderA = Gemm::Kernel::PaddingBuilder<
    OPT_PAD_TAG_A, Arch::AtlasA2, OptElementA, OptLayoutA, OPT_COMP_LEN_A>;
using OptGlobalPadA = typename OptPadBuilderA::Padding;
using OptLayoutMmadA = typename OptPadBuilderA::LayoutAfterPadding;

using OptPadBuilderB = Gemm::Kernel::PaddingBuilder<
    OPT_PAD_TAG_B, Arch::AtlasA2, OptElementB, OptLayoutB, OPT_COMP_LEN_B>;
using OptGlobalPadB = typename OptPadBuilderB::Padding;
using OptLayoutMmadB = typename OptPadBuilderB::LayoutAfterPadding;

using OptATypeMmad = Gemm::GemmType<OptElementA, OptLayoutMmadA>;
using OptBTypeMmad = Gemm::GemmType<OptElementB, OptLayoutMmadB>;

using OptTileBoth = OptTileCopy<Arch::AtlasA2, OptATypeMmad, OptBTypeMmad, OptCType>;
using OptTilePadA = OptTileCopy<Arch::AtlasA2, OptATypeMmad, OptBType, OptCType>;
using OptTilePadB = OptTileCopy<Arch::AtlasA2, OptAType, OptBTypeMmad, OptCType>;
using OptTileNone = OptTileCopy<Arch::AtlasA2, OptAType, OptBType, OptCType>;

using OptBmmBoth = Gemm::Block::BlockMmad<OptDispatchPolicy, OptL1TileShape, OptL0TileShape,
    OptATypeMmad, OptBTypeMmad, OptCType, void, OptTileBoth>;
using OptBmmPadA = Gemm::Block::BlockMmad<OptDispatchPolicy, OptL1TileShape, OptL0TileShape,
    OptATypeMmad, OptBType, OptCType, void, OptTilePadA>;
using OptBmmPadB = Gemm::Block::BlockMmad<OptDispatchPolicy, OptL1TileShape, OptL0TileShape,
    OptAType, OptBTypeMmad, OptCType, void, OptTilePadB>;
using OptBmmNone = Gemm::Block::BlockMmad<OptDispatchPolicy, OptL1TileShape, OptL0TileShape,
    OptAType, OptBType, OptCType, void, OptTileNone>;

using OMBoth30 = Gemm::Kernel::OptimizedMatmul<OptGlobalPadA, OptGlobalPadB, OptBmmBoth, OptBlockEpilogue, OptBlockScheduler30>;
using OMBoth31 = Gemm::Kernel::OptimizedMatmul<OptGlobalPadA, OptGlobalPadB, OptBmmBoth, OptBlockEpilogue, OptBlockScheduler31>;
using OM_A_30  = Gemm::Kernel::OptimizedMatmul<OptGlobalPadA, void,          OptBmmPadA, OptBlockEpilogue, OptBlockScheduler30>;
using OM_A_31  = Gemm::Kernel::OptimizedMatmul<OptGlobalPadA, void,          OptBmmPadA, OptBlockEpilogue, OptBlockScheduler31>;
using OM_B_30  = Gemm::Kernel::OptimizedMatmul<void,          OptGlobalPadB, OptBmmPadB, OptBlockEpilogue, OptBlockScheduler30>;
using OM_B_31  = Gemm::Kernel::OptimizedMatmul<void,          OptGlobalPadB, OptBmmPadB, OptBlockEpilogue, OptBlockScheduler31>;
using OMNone30 = Gemm::Kernel::OptimizedMatmul<void,          void,          OptBmmNone, OptBlockEpilogue, OptBlockScheduler30>;
using OMNone31 = Gemm::Kernel::OptimizedMatmul<void,          void,          OptBmmNone, OptBlockEpilogue, OptBlockScheduler31>;

template <class KernelType>
__global__ __aicore__ void opt_matmul_kernel(typename KernelType::Params params) {
    KernelType op;
    op(params);
}

inline bool IsNeedPadding(layout::RowMajor layout, uint32_t align) {
    if (layout.stride(0) < 65536) {
        return layout.stride(0) % align != 0;
    }
    return true;
}
inline bool IsNeedPadding(layout::ColumnMajor layout, uint32_t align) {
    if (layout.stride(1) < 65536) {
        return layout.stride(1) % align != 0;
    }
    return true;
}

size_t get_optimized_matmul_workspace_size(uint32_t M, uint32_t N, uint32_t K) {
    GemmCoord problemShape(M, N, K);
    typename OMBoth30::Arguments args{problemShape, nullptr, nullptr, nullptr};
    return OMBoth30::GetWorkspaceSize(args);
}

void optimized_matmul(uint32_t coreNum, void* stream, uint32_t M, uint32_t N, uint32_t K,
                      uint8_t* ptrA, uint8_t* ptrB, uint8_t* ptrC, uint8_t* workspace) {
    GemmCoord problemShape(M, N, K);
    OptLayoutA layoutA = OptLayoutA::template MakeLayout<OptElementA>(M, K);
    OptLayoutB layoutB = OptLayoutB::template MakeLayout<OptElementB>(K, N);

    bool padA = IsNeedPadding(layoutA, OPT_ALIGN_ELEM);
    bool padB = IsNeedPadding(layoutB, OPT_ALIGN_ELEM);

    if (M > N) {
        if (padA && padB) {
            typename OMBoth30::Arguments args{problemShape, ptrA, ptrB, ptrC};
            auto params = OMBoth30::ToUnderlyingArguments(args, workspace);
            opt_matmul_kernel<OMBoth30><<<coreNum, nullptr, stream>>>(params);
        } else if (padA) {
            typename OM_A_30::Arguments args{problemShape, ptrA, ptrB, ptrC};
            auto params = OM_A_30::ToUnderlyingArguments(args, workspace);
            opt_matmul_kernel<OM_A_30><<<coreNum, nullptr, stream>>>(params);
        } else if (padB) {
            typename OM_B_30::Arguments args{problemShape, ptrA, ptrB, ptrC};
            auto params = OM_B_30::ToUnderlyingArguments(args, workspace);
            opt_matmul_kernel<OM_B_30><<<coreNum, nullptr, stream>>>(params);
        } else {
            typename OMNone30::Arguments args{problemShape, ptrA, ptrB, ptrC};
            auto params = OMNone30::ToUnderlyingArguments(args, workspace);
            opt_matmul_kernel<OMNone30><<<coreNum, nullptr, stream>>>(params);
        }
    } else {
        if (padA && padB) {
            typename OMBoth31::Arguments args{problemShape, ptrA, ptrB, ptrC};
            auto params = OMBoth31::ToUnderlyingArguments(args, workspace);
            opt_matmul_kernel<OMBoth31><<<coreNum, nullptr, stream>>>(params);
        } else if (padA) {
            typename OM_A_31::Arguments args{problemShape, ptrA, ptrB, ptrC};
            auto params = OM_A_31::ToUnderlyingArguments(args, workspace);
            opt_matmul_kernel<OM_A_31><<<coreNum, nullptr, stream>>>(params);
        } else if (padB) {
            typename OM_B_31::Arguments args{problemShape, ptrA, ptrB, ptrC};
            auto params = OM_B_31::ToUnderlyingArguments(args, workspace);
            opt_matmul_kernel<OM_B_31><<<coreNum, nullptr, stream>>>(params);
        } else {
            typename OMNone31::Arguments args{problemShape, ptrA, ptrB, ptrC};
            auto params = OMNone31::ToUnderlyingArguments(args, workspace);
            opt_matmul_kernel<OMNone31><<<coreNum, nullptr, stream>>>(params);
        }
    }
}

} // namespace catlass_kernel
