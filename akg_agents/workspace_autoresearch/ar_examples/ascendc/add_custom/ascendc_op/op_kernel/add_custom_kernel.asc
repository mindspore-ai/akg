#include "kernel_operator.h"
#include "add_custom_tiling.h"

class KernelAdd {
 public:
  __aicore__ inline explicit KernelAdd(AscendC::TPipe* pipe) {
    pipe_ = pipe;
  }

  __aicore__ inline void Init(GM_ADDR x, GM_ADDR y, GM_ADDR z,
                              const __gm__ AddTilingData* tiling_data) {
    tiling = tiling_data;
    uint32_t block_idx = AscendC::GetBlockIdx();
    if (block_idx < tiling->blockNum - 1) {
      total = tiling->numPerCore;
      tileNum = total / TILE_LENGTH;
      tailTileElementNum = TILE_LENGTH;
    } else {
      total = tiling->tailNumLastCore;
      tileNum = (total + (TILE_LENGTH - 1)) / TILE_LENGTH;
      tailTileElementNum = total - TILE_LENGTH * (tileNum - 1);
    }

    uint64_t gm_offset = static_cast<uint64_t>(block_idx) * tiling->numPerCore;
    xGm.SetGlobalBuffer((__gm__ float*)x + gm_offset, total);
    yGm.SetGlobalBuffer((__gm__ float*)y + gm_offset, total);
    zGm.SetGlobalBuffer((__gm__ float*)z + gm_offset, total);

    pipe_->InitBuffer(inQueueX, DOUBLE_BUFFER, TILE_LENGTH * sizeof(float));
    pipe_->InitBuffer(inQueueY, DOUBLE_BUFFER, TILE_LENGTH * sizeof(float));
    pipe_->InitBuffer(outQueueZ, DOUBLE_BUFFER, TILE_LENGTH * sizeof(float));
  }

  __aicore__ inline void Process() {
    for (uint32_t i = 0; i < tileNum; i++) {
      uint32_t count = (i == tileNum - 1) ? tailTileElementNum : TILE_LENGTH;
      CopyIn(count);
      Compute(count);
      CopyOut(count);
    }
  }

 private:
  __aicore__ inline void CopyIn(uint32_t count) {
    AscendC::LocalTensor<float> x_local = inQueueX.AllocTensor<float>();
    AscendC::LocalTensor<float> y_local = inQueueY.AllocTensor<float>();
    AscendC::DataCopyPad(
        x_local, xGm, {1, static_cast<uint16_t>(count * sizeof(float)), 0, 0},
        {false, 0, 0, 0});
    AscendC::DataCopyPad(
        y_local, yGm, {1, static_cast<uint16_t>(count * sizeof(float)), 0, 0},
        {false, 0, 0, 0});
    inQueueX.EnQue(x_local);
    inQueueY.EnQue(y_local);
  }

  __aicore__ inline void Compute(uint32_t count) {
    AscendC::LocalTensor<float> x_local = inQueueX.DeQue<float>();
    AscendC::LocalTensor<float> y_local = inQueueY.DeQue<float>();
    AscendC::LocalTensor<float> z_local = outQueueZ.AllocTensor<float>();
    AscendC::Add(z_local, x_local, y_local, count);
    outQueueZ.EnQue<float>(z_local);
    inQueueX.FreeTensor(x_local);
    inQueueY.FreeTensor(y_local);
  }

  __aicore__ inline void CopyOut(uint32_t count) {
    AscendC::LocalTensor<float> z_local = outQueueZ.DeQue<float>();
    AscendC::DataCopyPad(
        zGm, z_local, {1, static_cast<uint16_t>(count * sizeof(float)), 0, 0});
    outQueueZ.FreeTensor(z_local);
  }

  AscendC::TPipe* pipe_;
  const __gm__ AddTilingData* tiling;
  AscendC::GlobalTensor<float> xGm;
  AscendC::GlobalTensor<float> yGm;
  AscendC::GlobalTensor<float> zGm;
  AscendC::TQue<AscendC::TPosition::VECIN, 1> inQueueX;
  AscendC::TQue<AscendC::TPosition::VECIN, 1> inQueueY;
  AscendC::TQue<AscendC::TPosition::VECOUT, 1> outQueueZ;
  uint32_t total;
  uint32_t tileNum;
  uint32_t tailTileElementNum;
};

extern "C" __global__ __vector__ void add_custom_kernel(
    GM_ADDR x, GM_ADDR y, GM_ADDR z, GM_ADDR tiling) {
  AscendC::TPipe pipe;
  KernelAdd op(&pipe);
  op.Init(x, y, z, (__gm__ AddTilingData*)tiling);
  op.Process();
}
